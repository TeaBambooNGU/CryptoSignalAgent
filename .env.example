APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_FILE_PATH=logs/app.log
LOG_FILE_MAX_MB=10
LOG_FILE_BACKUP_DAYS=5

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=crypto-signal-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

LLM_PROVIDER=minimax
LLM_MODEL=MiniMax-M2.5
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60
# MiniMax 通过 OpenAI-compatible 接口接入（ChatOpenAI）
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.chat
OPENAI_API_KEY=
OPENAI_BASE_URL=

EMBEDDING_PROVIDER=zhipu
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_BATCH_SIZE=64
ZHIPUAI_API_KEY=

MILVUS_ENABLED=true
MILVUS_ALLOW_FALLBACK=true
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_KNOWLEDGE_COLLECTION=knowledge_chunks
MILVUS_SIGNAL_COLLECTION=signal_chunks

MILVUS_MEMORY_COLLECTION=user_memory
VECTOR_DIM=384

MEM0_ENABLED=false
# 可选: platform / oss
MEM0_MODE=platform
# 仅在 MEM0_MODE=platform 时生效
MEM0_API_KEY=
# 仅在 MEM0_MODE=oss 时生效（建议使用独立 collection，避免和工程主表冲突）
MEM0_OSS_COLLECTION=mem0_memory
# 可选：覆盖 OSS 模式下智谱 Embedding 的 OpenAI-compatible Base URL
ZHIPU_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MEM0_ORG_ID=
MEM0_PROJECT_ID=

# 长期偏好自动抽取（DeepSeek 小模型）
MEMORY_EXTRACTOR_MODEL=deepseek-chat
MEMORY_EXTRACTOR_TIMEOUT_SECONDS=20
# 会话 auto 动作分类（DeepSeek 小模型）
CONVERSATION_ACTION_MODEL=deepseek-chat
CONVERSATION_ACTION_TIMEOUT_SECONDS=15
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 会话一致性与短期记忆存储
# 会话真相库（SQLite）
CONVERSATION_STORE_PATH=data/conversation_state.db
# 可选: memory / redis
SESSION_STORE_BACKEND=memory
# 仅 SESSION_STORE_BACKEND=redis 时生效
# 示例（带密码）：redis://:your_redis_password@127.0.0.1:6379/0
# 若启用 ACL 用户名，可用：redis://your_username:your_redis_password@127.0.0.1:6379/0
REDIS_URL=redis://:your_redis_password@127.0.0.1:6379/0
SESSION_MEMORY_TTL_SECONDS=86400
SESSION_MEMORY_MAX_ITEMS=50

# MCP 配置文件（Claude Code 风格，默认读取项目根目录 `.mcp.json`）
# 可改成绝对路径，例如 /etc/crypto-signal-agent/mcp.json
MCP_CONFIG_PATH=.mcp.json
# 可选：供 .mcp.json 中 crypto_news server 的 ${CRYPTOPANIC_AUTH_TOKEN} 占位符使用
CRYPTOPANIC_AUTH_TOKEN=
MCP_MAX_ROUNDS=4

# 研报 Prompt 中实时信号明细的最大保留条数；仅超限时触发裁剪
REPORT_SIGNAL_DETAIL_LIMIT=50
# 研报 Prompt 中单条信号 value 的最大字符数；超出将截断
REPORT_SIGNAL_VALUE_MAX_CHARS=120000
